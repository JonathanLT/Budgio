generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(cuid())
  googleId              String                 @unique
  email                 String                 @unique
  name                  String
  avatarUrl             String?
  theme                 String                 @default("clair")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  refreshTokens         RefreshToken[]
  memberships           HouseholdMember[]
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  householdLogs         HouseholdLog[]
  savingsGoals          SavingsGoal[]
}

model RefreshToken {
  id          String   @id @default(cuid())
  tokenPrefix String   @unique
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model Household {
  id                    String                 @id @default(cuid())
  name                  String
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  members               HouseholdMember[]
  transactions          Transaction[]
  categories            Category[]
  recurringTransactions RecurringTransaction[]
  logs                  HouseholdLog[]
  savingsGoals          SavingsGoal[]
}

model HouseholdMember {
  id          String    @id @default(cuid())
  role        Role      @default(MEMBER)
  userId      String
  householdId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@unique([userId, householdId])
}

model Category {
  id                    String                 @id @default(cuid())
  label                 String
  color                 String
  order                 Int                    @default(0)
  householdId           String
  household             Household              @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

// amount > 0 = entrée (vert), amount < 0 = sortie (rouge)
model Transaction {
  id            String               @id @default(cuid())
  label         String
  amount        Float
  categoryId    String?
  category      Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date          DateTime
  attachmentUrl String?
  isRecurring   Boolean              @default(false)
  recurringCron String?
  recurringId   String?
  recurring     RecurringTransaction? @relation(fields: [recurringId], references: [id], onDelete: SetNull)
  goalId           String?
  goal             SavingsGoal?         @relation(fields: [goalId], references: [id], onDelete: SetNull)
  goalContribution GoalContribution?
  householdId      String
  createdById      String
  household        Household            @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy        User                 @relation(fields: [createdById], references: [id])
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model RecurringTransaction {
  id          String        @id @default(cuid())
  label       String
  amount      Float
  frequency   FrequencyType
  dayOfWeek   Int?          // 0=dim..6=sam — pour WEEKLY
  dayOfMonth  Int?          // 1-31 — pour MONTHLY et YEARLY
  month       Int?          // 1-12 — pour YEARLY
  order       Int           @default(0)
  isActive    Boolean       @default(true)
  lastRunDate DateTime?
  householdId String
  categoryId  String?
  createdById String
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category    Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy   User          @relation(fields: [createdById], references: [id])
  transactions Transaction[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model HouseholdLog {
  id          String    @id @default(cuid())
  householdId String
  userId      String?
  event       String
  meta        Json?
  createdAt   DateTime  @default(now())

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([householdId, createdAt(sort: Desc)])
}

model SavingsGoal {
  id            String             @id @default(cuid())
  householdId   String
  name          String
  targetAmount  Float
  deadline      DateTime?
  isCompleted   Boolean            @default(false)
  order         Int                @default(0)
  createdById   String
  household     Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy     User               @relation(fields: [createdById], references: [id])
  contributions GoalContribution[]
  transactions  Transaction[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model GoalContribution {
  id            String       @id @default(cuid())
  goalId        String
  amount        Float
  note          String?
  date          DateTime     @default(now())
  transactionId String?      @unique
  goal          SavingsGoal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
}

enum Role {
  ADMIN
  MEMBER
}

enum FrequencyType {
  DAILY
  WEEKDAYS
  WEEKLY
  MONTHLY
  YEARLY
}
